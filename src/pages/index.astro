---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import { HOME } from "@consts";
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <h4 class="animate font-semibold text-black dark:text-white">
      Hi, I'm Dan Ulrich <span class="text-xl">👋🏻</span>
    </h4>
    <div class="space-y-16">
      <section>
        <article class="space-y-4">
          <p class="animate">
            Senior technical program manager and business analyst. I untangle
            complex programs and operations — and I'm building this site to
            show that work in more depth than a resume ever could.
          </p>
          <p class="animate">
            Salt Lake City, UT&nbsp;|&nbsp;Remote – U.S.
          </p>
          <p class="animate">
            <a href="/resume">Read the full interactive resume</a> — filterable
            by lane, with more depth than a one-page file allows.
          </p>
        </article>
      </section>
    </div>
  </Container>
</PageLayout>
